BINANCE_API_KEY=your_binance_testnet_api_key
BINANCE_SECRET_KEY=your_binance_testnet_secret_key
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
BINANCE_TESTNET=true
PORT=8080


# NOTE ON DATABASE_URL:
# In .env for local dev: postgresql+asyncpg://user:pass@localhost:5432/tradingbot
# In docker: postgresql+asyncpg://user:pass@postgres:5432/tradingbot
# The hostname changes from localhost to the service name postgres.
DATABASE_URL=postgresql+asyncpg://tradingbot:tradingbot@postgres:5432/tradingbot
POSTGRES_USER=tradingbot
POSTGRES_PASSWORD=tradingbot
POSTGRES_DB=tradingbot
